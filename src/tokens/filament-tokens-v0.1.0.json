      "secondary": { "background": { "value": "{global.color.navy.600}",       "type": "color" }, "text": { "value": "{global.color.gold.400}",       "type": "color" }, "border": { "value": "{global.color.navy.600}",       "type": "color" } },
      "danger":    { "background": { "value": "{global.color.vermillion.600}", "type": "color" }, "text": { "value": "{global.color.neutral.0}",      "type": "color" }, "border": { "value": "{global.color.vermillion.600}","type": "color" } },
      "info":      { "background": { "value": "{global.color.steel.400}",      "type": "color" }, "text": { "value": "{global.color.neutral.0}",      "type": "color" }, "border": { "value": "{global.color.steel.400}",      "type": "color" } },
      "ghost":     { "background": { "value": "transparent",                   "type": "color" }, "text": { "value": "{global.color.neutral.800}",    "type": "color" }, "border": { "value": "{global.color.neutral.400}",    "type": "color" } }
    },

    "feedback": {
      "danger":  { "background": { "value": "{global.color.vermillion.100}", "type": "color" }, "text": { "value": "{global.color.vermillion.800}", "type": "color" }, "accent": { "value": "{global.color.vermillion.600}", "type": "color" } },
      "info":    { "background": { "value": "{global.color.steel.50}",       "type": "color" }, "text": { "value": "{global.color.steel.800}",       "type": "color" }, "accent": { "value": "{global.color.steel.400}",       "type": "color" } },
      "warning": { "background": { "value": "{global.color.gold.100}",       "type": "color" }, "text": { "value": "{global.color.gold.800}",        "type": "color" }, "accent": { "value": "{global.color.gold.400}",        "type": "color" } }
    },

    "tag": {
      "gold":    { "background": { "value": "{global.color.gold.100}",       "type": "color" }, "text": { "value": "#7A5A10",                      "type": "color" } },
      "steel":   { "background": { "value": "{global.color.steel.50}",       "type": "color" }, "text": { "value": "#1E5E6E",                      "type": "color" } },
      "red":     { "background": { "value": "{global.color.vermillion.100}", "type": "color" }, "text": { "value": "{global.color.vermillion.800}","type": "color" } },
      "neutral": { "background": { "value": "{global.color.neutral.100}",    "type": "color" }, "text": { "value": "#546B78",                      "type": "color" } }
    },

    "input": {
      "background":  { "value": "{global.color.neutral.0}",    "type": "color" },
      "border":      { "value": "{global.color.neutral.200}",  "type": "color" },
      "text":        { "value": "{global.color.navy.600}",     "type": "color" },
      "placeholder": { "value": "{global.color.neutral.600}",  "type": "color" },
      "focusBorder": { "value": "#1F6475",                     "type": "color" },
      "focusRing":   { "value": "{global.shadow.focus-steel}", "type": "boxShadow" },
      "errorBorder": { "value": "{global.color.vermillion.600}","type": "color" },
      "errorRing":   { "value": "{global.shadow.focus-red}",   "type": "boxShadow" }
    },

    "elevation": {
      "card":    { "value": "{global.shadow.sm}", "type": "boxShadow" },
      "raised":  { "value": "{global.shadow.md}", "type": "boxShadow" },
      "modal":   { "value": "{global.shadow.lg}", "type": "boxShadow" },
      "overlay": { "value": "{global.shadow.xl}", "type": "boxShadow" }
    }
  },

  "dark": {
    "$themes": ["dark"],

    "background": {
      "page":    { "value": "#131D25", "type": "color", "$description": "Darkest — page base" },
      "surface": { "value": "#1C2D39", "type": "color", "$description": "Cards, panels, inputs" },
      "subtle":  { "value": "#1A2830", "type": "color", "$description": "Stat cells, meta blocks" },
      "overlay": { "value": "rgba(10, 22, 32, 0.75)", "type": "color", "$description": "Modal scrim" },
