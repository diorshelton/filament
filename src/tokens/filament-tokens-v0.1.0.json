      "subheading":  { "value": "#1F6475",                       "type": "color", "$description": "Spectral 400 italic · darkened steel for AA" },
      "body":        { "value": "{global.color.neutral.800}",    "type": "color", "$description": "#4A6070 · DM Sans 400" },
      "label":       { "value": "{global.color.navy.600}",       "type": "color", "$description": "#254052 · DM Sans 500" },
      "caption":     { "value": "#546B78",                       "type": "color", "$description": "DM Sans 400 · darkened for AA compliance" },
