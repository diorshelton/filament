      "caption":     { "value": "#7A9EAE",                      "type": "color", "$description": "DM Sans 400 · lightened for AA on dark" },
      "hint":        { "value": "#7A9EAE",                      "type": "color" },
      "link":        { "value": "#78BBCC",                      "type": "color" },
      "error":       { "value": "#F98480",                      "type": "color" },
      "disabled":    { "value": "#3A5060",                      "type": "color" },
      "placeholder": { "value": "#3A5060",                      "type": "color" },
      "nav-active":  { "value": "#A8C8D8",                      "type": "color" },
      "nav-muted":   { "value": "#3A5060",                      "type": "color" },
      "on-gold":     { "value": "#3A2C0A",                      "type": "color" },
      "on-navy":     { "value": "{global.color.gold.400}",      "type": "color" },
      "on-red":      { "value": "{global.color.neutral.0}",     "type": "color" },
      "on-steel":    { "value": "{global.color.neutral.0}",     "type": "color" }
    },

    "action": {
      "primary":   { "background": { "value": "{global.color.gold.400}",       "type": "color" }, "text": { "value": "#3A2C0A",                      "type": "color" }, "border": { "value": "{global.color.gold.600}",       "type": "color" } },
