      "strong":  { "value": "{global.color.neutral.400}",    "type": "color", "$description": "#C8C0B4 — ghost button, emphasis" },
      "focused": { "value": "#1F6475",                       "type": "color", "$description": "Darkened steel — AA compliant on white" },
      "error":   { "value": "{global.color.vermillion.600}", "type": "color" },
      "accent":  { "value": "{global.color.gold.400}",       "type": "color", "$description": "Pull quote bar, card top accent" }
