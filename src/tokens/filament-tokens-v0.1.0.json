      "subtle":  { "value": "{global.color.neutral.100}", "type": "color", "$description": "#EDEAE4 — stat cells, meta blocks" },
      "overlay": { "value": "rgba(37, 64, 82, 0.50)",     "type": "color", "$description": "Modal scrim" },
      "nav":     { "value": "{global.color.navy.600}",    "type": "color", "$description": "#254052 — top nav" }
    },

    "border": {
