      "link":        { "value": "#1F6475",                       "type": "color", "$description": "DM Sans 400 · darkened steel for AA" },
      "error":       { "value": "{global.color.vermillion.800}", "type": "color" },
      "disabled":    { "value": "{global.color.neutral.600}",    "type": "color" },
      "placeholder": { "value": "{global.color.neutral.600}",    "type": "color" },
      "nav-active":  { "value": "rgba(255, 255, 255, 0.90)",     "type": "color" },
      "nav-muted":   { "value": "rgba(255, 255, 255, 0.45)",     "type": "color" },
      "on-gold":     { "value": "#3A2C0A",                       "type": "color" },
      "on-navy":     { "value": "{global.color.gold.400}",       "type": "color" },
      "on-red":      { "value": "{global.color.neutral.0}",      "type": "color" },
      "on-steel":    { "value": "{global.color.neutral.0}",      "type": "color" }
    },

    "action": {
